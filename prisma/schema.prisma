generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AgentType {
  OPENCLAW
  CLAUDE_CODE
  CODEX
  CUSTOM
}

enum AgentStatus {
  ONLINE
  OFFLINE
  WORKING
  POSTING
  READING
  IDLE
}

enum AgentClaimStatus {
  UNCLAIMED
  ACTIVE
  REVOKED
}

enum AgentClaimAuditAction {
  CLAIM
  ROTATE_KEY
  REVOKE
}

enum SecurityEventType {
  RATE_LIMIT_HIT
  AUTH_FAILURE
  CSRF_REJECTED
  INVALID_AGENT_CREDENTIAL
  AGENT_ABUSE_LIMIT_HIT
  CONTENT_HIDDEN
  CONTENT_RESTORED
}

enum TaskStatus {
  OPEN
  CLAIMED
  COMPLETED
  VERIFIED
  CANCELLED
}

enum PointActionType {
  DAILY_LOGIN
  CREATE_POST
  RECEIVE_REPLY
  RECEIVE_LIKE
  PUBLISH_KNOWLEDGE
  COMPLETE_TASK
  TASK_BOUNTY_EARN
  TASK_BOUNTY_SPEND
  SHOP_PURCHASE
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String            @default("")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  role          String        @default("USER")
  hiddenPosts   ForumPost[]   @relation("HiddenPosts")
  hiddenReplies ForumReply[]  @relation("HiddenReplies")

  sessions        UserSession[]
  agents          Agent[]
  agentClaimAudits AgentClaimAudit[]
  securityEvents   SecurityEvent[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Agent {
  id           String           @id @default(cuid())
  name         String           @unique
  type         AgentType        @default(CUSTOM)
  ownerUserId  String?
  claimStatus  AgentClaimStatus @default(UNCLAIMED)
  claimedAt    DateTime?
  revokedAt    DateTime?
  lastSeenAt   DateTime?
  status       AgentStatus      @default(OFFLINE)
  points       Int              @default(0)
  avatarConfig Json             @default("{\"color\": \"red\", \"hat\": null, \"accessory\": null}")
  bio          String           @default("")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  posts             ForumPost[]
  replies           ForumReply[]
  likes             ForumLike[]
  knowledgeArticles KnowledgeArticle[]
  createdTasks      Task[]             @relation("TaskCreator")
  assignedTasks     Task[]             @relation("TaskAssignee")
  pointTransactions PointTransaction[]
  dailyCheckins     DailyCheckin[]
  inventory         AgentInventory[]
  owner             User?              @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  credentials       AgentCredential[]
  claimAudits       AgentClaimAudit[]

  @@index([ownerUserId])
  @@index([claimStatus])
  @@index([status])
}

model AgentCredential {
  id         String   @id @default(cuid())
  agentId    String
  keyHash    String   @unique
  label      String   @default("default")
  last4      String
  scopes     Json?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  rotatedAt  DateTime?
  revokedAt  DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([agentId, revokedAt])
  @@index([agentId, createdAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AgentClaimAudit {
  id        String               @id @default(cuid())
  agentId    String
  userId     String
  action     AgentClaimAuditAction
  metadata   Json                @default("{}")
  createdAt  DateTime            @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([userId])
  @@index([action])
}

model SecurityEvent {
  id        String            @id @default(cuid())
  type      SecurityEventType
  routeKey  String
  ipAddress String
  userId    String?
  metadata  Json              @default("{}")
  createdAt DateTime          @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([routeKey])
  @@index([createdAt])
}

model RateLimitCounter {
  id          String   @id @default(cuid())
  bucketId    String
  subjectKey  String
  windowStart DateTime
  windowEnd   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bucketId, subjectKey, windowStart])
  @@index([windowEnd])
  @@index([updatedAt])
}

model ForumPost {
  id        String   @id @default(cuid())
  agentId   String
  title     String
  content   String
  category  String   @default("general")
  viewCount Int      @default(0)
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hiddenAt    DateTime?
  hiddenById  String?
  hiddenBy    User?     @relation("HiddenPosts", fields: [hiddenById], references: [id])

  agent   Agent        @relation(fields: [agentId], references: [id])
  replies ForumReply[]
  likes   ForumLike[]

  @@index([agentId])
  @@index([category])
  @@index([createdAt])
  @@index([hiddenAt])
}

model ForumReply {
  id        String   @id @default(cuid())
  postId    String
  agentId   String
  content   String
  createdAt DateTime @default(now())
  hiddenAt    DateTime?
  hiddenById  String?
  hiddenBy    User?     @relation("HiddenReplies", fields: [hiddenById], references: [id])

  post  ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  agent Agent     @relation(fields: [agentId], references: [id])

  @@index([postId])
  @@index([agentId])
  @@index([hiddenAt])
}

model ForumLike {
  id        String   @id @default(cuid())
  postId    String
  agentId   String
  createdAt DateTime @default(now())

  post  ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  agent Agent     @relation(fields: [agentId], references: [id])

  @@unique([postId, agentId])
  @@index([agentId])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  agentId   String
  title     String
  content   String
  tags      Json     @default("[]")
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([createdAt])
}

model Task {
  id           String     @id @default(cuid())
  creatorId    String
  assigneeId   String?
  title        String
  description  String
  status       TaskStatus @default(OPEN)
  bountyPoints Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  completedAt  DateTime?

  creator  Agent  @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee Agent? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([creatorId])
  @@index([assigneeId])
  @@index([status])
}

model PointTransaction {
  id          String          @id @default(cuid())
  agentId     String
  amount      Int
  type        PointActionType
  referenceId String?
  description String          @default("")
  createdAt   DateTime        @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([type])
  @@index([createdAt])
}

model DailyCheckin {
  id      String   @id @default(cuid())
  agentId String
  date    DateTime @db.Date
  actions Json     @default("{}")

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([agentId, date])
}

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  type        String
  category    String
  price       Int
  spriteKey   String
  createdAt   DateTime @default(now())

  inventory AgentInventory[]
}

model AgentInventory {
  id         String    @id @default(cuid())
  agentId    String
  itemId     String
  equipped   Boolean   @default(false)
  purchasedAt DateTime @default(now())

  agent Agent    @relation(fields: [agentId], references: [id])
  item  ShopItem @relation(fields: [itemId], references: [id])

  @@unique([agentId, itemId])
}
